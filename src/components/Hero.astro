---
// Hero.astro — top section with tagline
import Nav from './Nav.astro';
---

<Nav />

<section class="max-w-4xl mx-auto px-6 pt-24 pb-20">
  <div class="max-w-2xl">
    <p class="font-mono text-xs text-[var(--color-accent)] tracking-widest uppercase mb-4">
      Software Architect &amp; Tool Builder
    </p>
    <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight text-[var(--color-text)] leading-[1.1] mb-6">
      Building tools that<br />
      <span class="text-[var(--color-accent)]">stay out of your way.</span>
    </h1>
    <p class="text-lg text-[var(--color-muted)] leading-relaxed">
      I design and build developer tooling with a focus on simplicity,
      privacy, and correctness. No SaaS lock-in, no telemetry, no surprises.
    </p>
  </div>
</section>
