---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Layout
  title="Blog — cyferlawyn"
  description="Thoughts on software architecture, developer tooling, cloud-native systems, and AI orchestration."
>
  <!-- Top bar -->
  <header class="border-b border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto px-6 py-5 flex items-center justify-between">
      <a
        href="/"
        class="font-mono text-sm font-medium text-[var(--color-accent)] tracking-wide hover:opacity-80 transition-opacity"
      >
        cyferlawyn
      </a>
      <nav>
        <ul class="flex items-center gap-6 text-sm text-[var(--color-muted)]">
          <li><a href="/#about" class="hover:text-[var(--color-text)] transition-colors">About</a></li>
          <li><a href="/#projects" class="hover:text-[var(--color-text)] transition-colors">Projects</a></li>
          <li>
            <a href="/blog" class="text-[var(--color-text)] transition-colors">Blog</a>
          </li>
          <li>
            <a href="https://github.com/cyferlawyn" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-text)] transition-colors">GitHub</a>
          </li>
        </ul>
      </nav>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-6 py-20 flex-1">
    <div class="mb-12">
      <p class="font-mono text-xs text-[var(--color-accent)] tracking-widest uppercase mb-3">Blog</p>
      <h1 class="text-3xl font-semibold tracking-tight text-[var(--color-text)]">
        Writing
      </h1>
      <p class="mt-3 text-[var(--color-muted)] text-sm leading-relaxed max-w-xl">
        Occasional posts on software architecture, developer tooling, cloud-native systems, and AI orchestration.
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="text-[var(--color-muted)] text-sm">No posts published yet.</p>
    ) : (
      <ol class="space-y-px">
        {posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-6 rounded-lg px-4 py-4 -mx-4 transition-colors hover:bg-[var(--color-surface)]"
            >
              <time
                datetime={post.data.date.toISOString()}
                class="shrink-0 font-mono text-xs text-[var(--color-muted)] w-28"
              >
                {formatDate(post.data.date)}
              </time>
              <div class="flex-1 min-w-0">
                <span class="text-[var(--color-text)] font-medium group-hover:text-[var(--color-accent)] transition-colors">
                  {post.data.title}
                </span>
                <p class="mt-0.5 text-sm text-[var(--color-muted)] line-clamp-2">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-2">
                    {post.data.tags.map((tag: string) => (
                      <span class="rounded border border-[var(--color-border)] px-2 py-0.5 font-mono text-xs text-[var(--color-muted)]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </li>
        ))}
      </ol>
    )}
  </main>

  <footer class="border-t border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-mono text-xs text-[var(--color-muted)]">
        &copy; {new Date().getFullYear()} cyferlawyn
      </p>
      <a href="/" class="text-xs text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">
        &larr; Back to home
      </a>
    </div>
  </footer>
</Layout>
